# API KEYS
FIREWORKS_API_KEY=
OPENAI_API_KEY=

# EXTRACTION MODEL
OPENAI_MODEL="gpt-5-mini"
REASONING_EFFORT="medium"

# RUNTIME
MAX_REQUEST_BODY_SIZE_MB=1024

# RATE LIMITS
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=1

# AUDIO PROCESSING (FFMPEG)
FFMPEG_TIMEOUT_MS=1800000
FASTER_FFMPEG_ENABLED=true

# SERVER PORT
PORT=7070

# POSTGRES CONNECTION STRING
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ad_segment_trimmer
