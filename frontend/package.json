{
  "name": "frontend",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "bun --env-file=../.env --env-file=.env x vite dev --host 0.0.0.0 --port 6030",
    "build": "bun --env-file=../.env --env-file=.env x vite build",
    "format": "prettier --write .",
    "lint": "prettier --check .",
    "preview": "bun --env-file=../.env --env-file=.env x vite preview --host 0.0.0.0 --port 6030",
    "start": "bun --env-file=../.env --env-file=.env .output/server/index.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@better-auth/api-key": "^1.5.3",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "better-auth": "^1.5.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "kysely": "^0.28.8",
    "lucide-react": "^0.577.0",
    "motion": "^12.35.0",
    "nitro": "npm:nitro-nightly@latest",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "tailwindcss-motion": "^1.1.0",
    "tw-animate-css": "^1.3.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "prettier": "latest",
    "prettier-plugin-organize-imports": "latest",
    "prettier-plugin-tailwindcss": "latest",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
