{
  "name": "ad-segment-trimmer",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "bun --env-file=.env x vite dev --host 0.0.0.0",
    "build": "bun --env-file=.env x vite build",
    "db:studio": "bun --env-file=.env x drizzle-kit studio",
    "format": "prettier --write .",
    "lint": "prettier --check .",
    "logout": "bun --env-file=.env scripts/logout.ts",
    "preview": "bun --env-file=.env x vite preview --host 0.0.0.0",
    "prune": "bun --env-file=.env scripts/prune.ts",
    "start": "bun --env-file=.env .output/server/index.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui-components/react": "^1.0.0-rc.0",
    "@better-auth/api-key": "^1.5.4",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.166.6",
    "better-auth": "^1.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.577.0",
    "motion": "^12.35.2",
    "nitro": "npm:nitro-nightly@latest",
    "openai": "latest",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tailwindcss-motion": "^1.1.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/devtools-vite": "latest",
    "@types/node": "^22.19.15",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "drizzle-kit": "^0.31.6",
    "prettier": "latest",
    "prettier-plugin-organize-imports": "latest",
    "prettier-plugin-tailwindcss": "latest",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
